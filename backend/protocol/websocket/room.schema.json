{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id":     "https://example.com/room.schema.json",
  "title":   "RoomPayload",

  "oneOf": [
    { "$ref": "#/$defs/CommandJoin"  },
    { "$ref": "#/$defs/CommandLeave" },
    { "$ref": "#/$defs/EventJoined"  }
  ],
  "discriminator": {
    "propertyName": "kind",
    "mapping": {
      "join":   "#/$defs/CommandJoin",
      "leave":  "#/$defs/CommandLeave",
      "joined": "#/$defs/EventJoined"
    }
  },

  "$defs": {
    "CommandJoin": {
      "type": "object",
      "properties": {
        "kind": { "const": "join" },
        "room": { "type": "string" }
      },
      "required": ["kind", "room"],
      "additionalProperties": false
    },

    "CommandLeave": {
      "type": "object",
      "properties": {
        "kind": { "const": "leave" },
        "room": { "type": "string" }
      },
      "required": ["kind", "room"],
      "additionalProperties": false
    },

    "EventJoined": {
      "type": "object",
      "properties": {
        "kind": { "const": "joined" },
        "room": { "type": "string" }
      },
      "required": ["kind", "room"],
      "additionalProperties": false
    }
  }
}
