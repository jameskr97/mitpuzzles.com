{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id":     "https://example.com/ping.schema.json",
  "title":   "PingPayload",

  "oneOf": [
    { "$ref": "#/$defs/CommandPing" },
    { "$ref": "#/$defs/EventPong"   }
  ],
  "discriminator": {
    "propertyName": "kind",
    "mapping": {
      "ping": "#/$defs/CommandPing",
      "pong": "#/$defs/EventPong"
    }
  },

  "$defs": {
    "CommandPing": {
      "type": "object",
      "properties": {
        "kind":    {
          "const": "ping",
          "default": "ping"
        },
        "payload": {
          "type": "object",
          "title": "CommandPingPayload",
          "properties": {
            "client_ts": { "type": "integer", "minimum": 0 }
          },
          "required": ["client_ts"],
          "additionalProperties": false
        }
      },
      "required": ["kind", "payload"],
      "additionalProperties": false
    },

    "EventPong": {
      "type": "object",
      "properties": {
        "kind": { "const": "pong" },
        "payload": {
          "$ref": "#/$defs/EventPongPayload"
        }
      },
      "required": ["kind", "payload"],
      "additionalProperties": false
    },
    "EventPongPayload": {
      "type": "object",
      "title": "EventPongPayload",
      "properties": {
        "client_ts":   { "type": "integer", "minimum": 0 },
        "server_recv": { "type": "integer", "minimum": 0 }
      },
      "required": ["client_ts", "server_recv"],
      "additionalProperties": false

    }
  }
}
