{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/experiment.schema.json",
  "title": "ExperimentPayload",
  "oneOf": [
    {
      "$ref": "#/$defs/CommandExperimentConsent"
    },
    {
      "$ref": "#/$defs/CommandExperimentStep"
    },
    {
      "$ref": "#/$defs/EventExperimentState"
    },
    {
      "$ref": "#/$defs/EventExperimentBegin"
    },
    {
      "$ref": "#/$defs/CommandExperimentNextTrial"
    },
    {
      "$ref": "#/$defs/CommandExperimentFinishTrial"
    }
  ],
  "discriminator": {
    "propertyName": "kind",
    "mapping": {
      "experiment_consent": "#/$defs/CommandExperimentConsent",
      "experiment_step": "#/$defs/CommandExperimentStep",
      "experiment_init": "#/$defs/CommandExperimentInit"
    }
  },
  "$defs": {
    "CommandExperimentConsent": {
      "type": "object",
      "properties": {
        "kind": { "const": "experiment_consent" }
      },
      "additionalProperties": false
    },
    "CommandExperimentStep": {
      "type": "object",
      "properties": {
        "kind": {
          "const": "experiment_step"
        },
        "step_name": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "CommandExperimentNextTrial": {
      "type": "object",
      "properties": {
        "kind": { "const": "experiment_next_trial" },
        "points": { "type": "integer" }
      },
      "required": ["kind", "points"],
      "additionalProperties": false
    },
    "CommandExperimentFinishTrial": {
      "type": "object",
      "properties": {
        "kind": { "const": "experiment_finish_trial" },
        "points": { "type": "integer" }
      },
      "required": ["kind", "points"],
      "additionalProperties": false
    },

    "EventExperimentState": {
      "type": "object",
      "properties": {
        "kind": { "const": "event_experiment_state" },
        "boards": {"type": "array", "items": { "type": "object",  "additionalProperties": true }},
        "current_trial": { "type": "integer" },
        "current_step": { "type": "string" },
        "participation_id": { "type": "string" },
        "completed": { "type": "boolean" },
        "total_points": { "type": "integer" }
      },
      "required": ["kind", "current_step", "current_trial", "boards", "participation_id", "completed", "total_points"],
      "additionalProperties": true
    },
    "EventExperimentBegin": {
      "type": "object",
      "properties": {
        "kind": {
          "const": "experiment_begin"
        },
        "experiment_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "EventExperimentTrialsComplete": {
      "type": "object",
      "properties": {
        "kind": { "const": "number_of_mistakes" },
        "experiment_id": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
