{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/game.schema.json",
  "title": "GamePayload",
  "oneOf": [
    { "$ref": "#/$defs/CommandLoad" },
    { "$ref": "#/$defs/CommandRefresh" },
    { "$ref": "#/$defs/CommandAction" },
    { "$ref": "#/$defs/CommandClear" },
    { "$ref": "#/$defs/CommandResume" },
    { "$ref": "#/$defs/CommandSubmit" },

    { "$ref": "#/$defs/CommandToggleTutorial" },
    { "$ref": "#/$defs/EventState" },
    { "$ref": "#/$defs/EventSubmitResult" }
  ],
  "discriminator": {
    "propertyName": "kind"
  },
  "$defs": {
    "SupportedPuzzleTypes": {
      "type": "string",
      "title": "SupportedPuzzleTypes",
      "enum": [
        "sudoku",
        "minesweeper",
        "lightup",
        "tents",
        "kakurasu"
      ]
    },
    "PuzzleAttemptBase": {
      "properties": {
        "attempt_id": {
          "type": "string"
        },
        "puzzle_type": {
          "$ref": "#/$defs/SupportedPuzzleTypes"
        }
      },
      "required": [
        "attempt_id",
        "puzzle_type"
      ],
      "additionalProperties": false
    },

    "CommandLoad": {
      "type": "object",
      "description": "Load a puzzle session",
      "properties": {
        "kind": { "const": "load" },
        "puzzle_type": { "$ref": "#/$defs/SupportedPuzzleTypes" }
      },
      "required": ["kind", "puzzle_type"],
      "additionalProperties": false
    },
    "CommandResume": {
      "title": "CommandResume",
      "allOf": [
        { "$ref": "#/$defs/PuzzleAttemptBase" },
        {
          "type": "object",
          "properties": { "kind": { "const": "resume" } },
          "required": ["kind"]
        }
      ]
    },

    "CommandRefresh": {
      "title": "CommandRefresh",
      "description": "Get a new puzzle",
      "allOf": [
        { "$ref": "#/$defs/PuzzleAttemptBase" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "refresh" },
            "size": { "type": ["string", "null"] },
            "difficulty": { "type": ["string", "null"] }
          },
          "required": ["kind"]
        }
      ]
    },

    "CommandAction": {
      "title": "CommandAction",
      "allOf": [
        { "$ref": "#/$defs/PuzzleAttemptBase" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "action" },
            "payload": { "type": "object", "additionalProperties": true }
          },
          "required": ["kind", "payload"],
          "additionalProperties": false

        }
      ]
    },

    "CommandClear": {
      "title": "CommandClear",
      "allOf": [
        { "$ref": "#/$defs/PuzzleAttemptBase" },
        {
          "type": "object",
          "properties": { "kind": { "const": "clear" } },
          "required": ["kind"]
        }
      ],
      "additionalProperties": false
    },

    "CommandSubmit": {
      "title": "CommandSubmit",
      "allOf": [
        { "$ref": "#/$defs/PuzzleAttemptBase" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "submit" },
            "client_duration": { "type": "number" }
          },
          "required": ["kind", "client_duration"]
        }
      ],
      "additionalProperties": false
    },
    "CommandToggleTutorial": {
      "title": "CommandToggleTutorial",
      "allOf": [
        { "$ref": "#/$defs/PuzzleAttemptBase" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "toggle_tutorial" },
            "enabled": { "type": "boolean" }
          },
          "required": ["kind", "enabled"]
        }
      ],
      "additionalProperties": false
    },

    "EventState": {
      "title": "EventState",
      "allOf": [
        { "$ref": "#/$defs/PuzzleAttemptBase" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "state" },
            "rows": { "type": "integer" },
            "cols": { "type": "integer" },
            "board": { "type": "array", "items": { "type": "integer" }},
            "immutable": { "type": "array", "items": { "type": "integer" }},
            "violations": { "type": "array", "items": { "type": "object" }},
            "solved": { "type": "boolean" }
          },
          "required": ["kind", "rows", "cols", "board", "immutable"]
        }
      ],
      "additionalProperties": true
    },
    "EventSubmitResult": {
      "title": "EventSubmitResult",
      "allOf": [
        { "$ref": "#/$defs/PuzzleAttemptBase" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "submit_result" },
            "solved": { "type": "boolean" }
          },
          "required": ["kind", "solved"],
          "additionalProperties": false
        }
      ]
    }
  }
}
