{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/room.schema.json",
  "title": "WebsocketEnvelope",
  "type": "object",
  "properties": {
    "ts": {
      "type": "number",
      "minimum": 0
    },
    "payload": {
      "title": "Payload",
      "oneOf": [
        { "$ref": "game.schema.json" },
        { "$ref": "identify.schema.json" },
        { "$ref": "ping.schema.json" },
        { "$ref": "experiment.schema.json" },
        {
          "title": "EventError",
          "type": "object",
          "allOf": [
            {
              "properties": {
                "kind": { "const": "error" },
                "code": { "type": "string" },
                "message": { "type": "string" }
              },
              "required": ["kind", "code", "message"],
              "additionalProperties": false
            }
          ]
        }
      ]
    }
  },
  "required": ["ts", "payload"],
  "additionalProperties": false
}
