{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id":     "https://example.com/identify.schema.json",
  "title":   "IdentifyPayload",
  "oneOf": [
    { "$ref": "#/$defs/CommandIdentify" },
    { "$ref": "#/$defs/EventIdentified" },
    { "$ref": "#/$defs/EventIdentifyError" }
  ],
  "discriminator": { "propertyName": "kind" },
  "$defs": {
    "CommandIdentify": {
      "type":"object",
      "properties": {
        "kind": { "const": "identify" },
        "mode": { "enum":["freeplay","prolific"] },
        "prolific_subject_id": { "type":["string","null"] },
        "prolific_study_id":   { "type":["string","null"] },
        "prolific_session_id": { "type":["string","null"] },
        "experiment_id":       { "type": "string" }
      },
      "required":["kind","mode"],
      "additionalProperties": false
    },

    "EventIdentified": {
      "type":"object",
      "properties": {
        "kind":       { "const": "identified" },
        "mode":       { "enum": ["freeplay", "prolific"] }
      },
      "required":["kind","new","mode"],
      "additionalProperties": false
    },
    "EventIdentifyError": {
      "type":"object",
      "properties": {
        "kind":       { "const": "identify_error" },
        "code": { "type": "integer" },
        "msg":    { "type": "string" }
      },
      "required":["kind","message"],
      "additionalProperties": false
    }
  }
}
