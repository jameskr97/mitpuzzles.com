{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id":     "https://example.com/identify.schema.json",
  "title":   "IdentifyPayload",

  "oneOf": [
    { "$ref": "#/$defs/CommandIdentify" },
    { "$ref": "#/$defs/EventIdentified" },
    { "$ref": "#/$defs/EventError" }
  ],
  "discriminator": {
    "propertyName": "kind",
    "mapping": {
      "identify":   "#/$defs/CommandIdentify",
      "identified": "#/$defs/EventIdentified",
      "error":      "#/$defs/EventError"
    }
  },

  "$defs": {
    "CommandIdentify": {
      "type":"object",
      "properties": {
        "kind": { "const": "identify" },

        "mode": { "enum":["freeplay","prolific"] },
        "prolific_subject_id": { "type":["string","null"] },
        "prolific_study_id":   { "type":["string","null"] },
        "prolific_session_id": { "type":["string","null"] },

        "session_id":   { "type":["string","null"] }
      },
      "required":["kind","mode"],
      "additionalProperties": false
    },

    "EventIdentified": {
      "type":"object",
      "properties": {
        "kind":       { "const": "identified" },
        "session_id": { "type": "string" },
        "new":        { "type": "boolean" },
        "mode":       { "enum": ["freeplay", "prolific"] }
      },
      "required":["kind","session_id","new","mode"],
      "additionalProperties": false

    },

    "EventError": {
      "type":"object",
      "properties": {
        "kind": { "const":"error" },
        "code": { "type":"string" },
        "msg":  { "type":"string" }
      },
      "required":["kind","code","msg"],
      "additionalProperties": false
    }
  }
}
