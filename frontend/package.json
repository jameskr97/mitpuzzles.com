{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build-prod": "vue-tsc -b && vite build --base=/static/frontend --outDir=./dist/static/frontend",
    "watch": "vue-tsc -b && vite build --watch",
    "preview": "vite preview",
    "fmt": "prettier --write src/",
    "check": "prettier --check src/"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.0.6",
    "@vee-validate/zod": "^4.15.0",
    "@vueuse/core": "^12.7.0",
    "axios": "^1.7.9",
    "oh-vue-icons": "^1.0.0-rc3",
    "pinia": "^3.0.1",
    "tailwindcss": "^4.0.6",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "daisyui": "^5.0.0-beta.7",
    "prettier": "^3.5.3",
    "typescript": "~5.7.2",
    "vite": "^6.1.1",
    "vite-plugin-vue-devtools": "^7.7.2",
    "vue-tsc": "^2.2.0"
  }
}
