{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": [
    "src/features/experiment/views/ViewMarkdown.vue",
    "src/features/experiment/views/*.vue"
  ],
  "scripts": {
    "dev": "vite --host",
    "build": "vue-tsc -b && vite build",
