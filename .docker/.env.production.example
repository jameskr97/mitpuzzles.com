# Production environment configuration
ENVIRONMENT=production
DOMAIN=mitpuzzles.com

# Database configuration
POSTGRES_USER=mitpuzzles
POSTGRES_PASSWORD=your-secure-postgres-password
POSTGRES_DB=mitpuzzles
POSTGRES_PORT=5432

# Backend secret key (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here

# Docker image configuration (production uses pre-built images)
BACKEND_IMAGE=ghcr.io/jameskr97/mitpuzzles.com/backend-dev:latest
FRONTEND_IMAGE=ghcr.io/jameskr97/mitpuzzles.com/frontend-dev:latest

# Port configuration (production uses standard HTTP/HTTPS ports)
FRONTEND_PORTS=80:80,443:443
BACKEND_PORTS=8000:8000
VALKEY_PORT=6379
FLOWER_PORT=5555

# Celery configuration
CELERY_BROKER_URL=redis://valkey:6379/0
CELERY_RESULT_BACKEND=redis://valkey:6379/0

# External services (required for production)
RESEND_API_KEY=your-production-resend-api-key
OAUTH_GOOGLE_CLIENT_ID=your-production-google-client-id
OAUTH_GOOGLE_CLIENT_SECRET=your-production-google-client-secret